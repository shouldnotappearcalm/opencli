{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencli.dev/schemas/skill-args.schema.json",
  "title": "OpenCLI Skill Unified Args",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "domain": {
      "type": "string",
      "enum": ["content", "community", "finance", "devtools"]
    },
    "action": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "minLength": 1 },
    "query": { "type": "string" },
    "symbol": { "type": "string" },
    "repo": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$",
      "description": "owner/repo"
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "default": 20
    },
    "timeRange": {
      "type": "string",
      "enum": ["1d", "7d", "30d", "24h"]
    },
    "output": {
      "type": "string",
      "enum": ["table", "json", "markdown"],
      "default": "table"
    },
    "dryRun": { "type": "boolean", "default": true },
    "confirm": { "type": "boolean", "default": false },
    "draft": { "type": "string" }
  },
  "required": ["domain", "action", "platform"],
  "allOf": [
    {
      "if": {
        "properties": {
          "action": { "enum": ["publish", "post", "reply", "comment", "checkin", "delete", "merge"] }
        },
        "required": ["action"]
      },
      "then": {
        "properties": { "confirm": { "const": true } },
        "required": ["confirm"]
      }
    }
  ],
  "examples": [
    {
      "domain": "content",
      "action": "fetch_hot",
      "platform": "bilibili",
      "limit": 20,
      "timeRange": "1d",
      "output": "markdown"
    },
    {
      "domain": "devtools",
      "action": "list_pr",
      "platform": "gh",
      "repo": "openclaw/openclaw",
      "limit": 20,
      "output": "table"
    },
    {
      "domain": "content",
      "action": "publish",
      "platform": "twitter",
      "draft": "今天的 AI Agent 观察...",
      "dryRun": true,
      "confirm": true
    }
  ]
}
